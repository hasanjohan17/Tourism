{
  "name": "tourism",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "deploy:root": "npm run build && powershell -Command \"if (-not (Test-Path 'assets')) { New-Item -ItemType Directory -Path 'assets' | Out-Null }; Copy-Item -Path 'dist/assets/*' -Destination 'assets' -Recurse -Force\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
